# 선택: 비우면 코드에 있는 기본 Supabase 프로젝트를 사용합니다.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# 세대 검증: Supabase 테이블 yyc_resident_registry + RPC verify_yyc_resident
# (supabase/sql/yyc_resident_registry.sql 실행 후, npm run db:residents-sql 로 INSERT 생성)

# --- 신청 시 엑셀 누적 (docs/APPEND_WORKBOOK.md 참고) ---
# Storage 공개 워크북 URL → 관리자 엑셀 내려받기 시 이 파일을 그대로 저장
# VITE_LIVE_WORKBOOK_URL=https://xxxx.supabase.co/storage/v1/object/public/application-workbook/yyc-contract-live_V1.xlsx

# 신청 직후 Edge 호출(비밀은 번들 노출됨). Webhook 사용 시 비워 두는 것을 권장.
# VITE_APPEND_WORKBOOK_ON_SUBMIT=1
# VITE_WORKBOOK_APPEND_URL=https://xxxx.supabase.co/functions/v1/append-workbook-row
# VITE_WORKBOOK_APPEND_SECRET=
